//DESIGN CODE
module nand_gate(input A,input B,output Y);
nand(Y, A, B);
endmodule

//TEST BENCH
module nand_gate_tb;

reg A, B;
wire Y;

nand_gate d1 (.A(A),.B(B),.Y(Y));

initial begin
  
  // To Open EPWave after run in EDA playground
  $dumpfile("nand_gate.vcd");
  $dumpvars(0, nand_gate_tb);
  
         A = 0; B = 0;
    #10; A = 0; B = 1;
    #10; A = 1; B = 0;
    #10; A = 1; B = 1;
    #10;$finish;
end
endmodule
