//DESIGN CODE
module xnor_gate(input A,input B,output Y);
xnor(Y, A, B);
endmodule

//TEST BENCH

module xnor_gate_tb;
reg A, B;
wire Y;
xnor_gate E7 (.A(A),.B(B),.Y(Y));

initial begin
//TO Open EPWave after run in EDA playground
  $dumpfile("xnor_gate.vcd");
  $dumpvars(0, xnor_gate_tb);
  
    A = 0; B = 0;
    #10;A = 0; B = 1;
    #10; A = 1; B = 0;
    #10;A = 1; B = 1;
    #10;$finish;
  
end
endmodule
