//Design code 
module and_gate(
    input A,
    input B,
    output Y
);

and(Y, A, B);
endmodule 

//Test Bench 

module and_gate_tb;
reg A, B;
wire Y;
  
and_gate a1(.A(A),.B(B),.Y(Y));

initial begin
// Open EPWave after run in eda playground
